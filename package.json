{
  "name": "tractodb",
  "version": "0.1.0",
  "description": "Modern minimalist desktop database manager",
  "author": "Pozzdol <fkriachmd@gmail.com>",
  "homepage": "https://github.com/pozzdol/TractoDB",
  "repository": "https://github.com/pozzdol/TractoDB",
  "main": "dist-electron/main.js",
  "private": true,
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-builder install-app-deps",
    "dev": "vite",
    "dev:electron": "electron .",
    "start": "concurrently \"bun run dev\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "tsc && vite build && electron-builder",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "package:linux": "electron-builder --linux deb AppImage",
    "package:all": "electron-builder --linux --mac --win",
    "typecheck": "tsc --noEmit",
    "typecheck:electron": "tsc -p tsconfig.electron.json --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{ts,tsx,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,css,json,md}\"",
    "preview": "vite preview"
  },
  "dependencies": {
    "@flaticon/flaticon-uicons": "^3.3.1",
    "@monaco-editor/react": "^4.6.0",
    "@tabler/icons-react": "^3.0.0",
    "better-sqlite3": "^11.0.0",
    "electron-store": "^10.0.0",
    "ioredis": "^5.4.0",
    "keytar": "^7.9.0",
    "monaco-editor": "^0.52.0",
    "mysql2": "^3.11.0",
    "pg": "^8.13.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ssh2": "^1.16.0",
    "uuid": "^10.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/ssh2": "^1.15.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.8.4",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "wait-on": "^8.0.0"
  }
}
